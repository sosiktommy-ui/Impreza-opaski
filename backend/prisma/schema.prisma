generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum Role {
  ADMIN
  OFFICE
  COUNTRY
  CITY
}

enum ItemType {
  BLACK
  WHITE
  RED
  BLUE
}

enum TransferStatus {
  SENT
  ACCEPTED
  DISCREPANCY_FOUND
  REJECTED
  CANCELLED
}

enum CityStatus {
  ACTIVE
  LOW
  INACTIVE
}

enum EntityType {
  ADMIN
  OFFICE
  COUNTRY
  CITY
}

enum NotificationType {
  INCOMING_TRANSFER
  ACCEPTANCE_REQUIRED
  TRANSFER_ACCEPTED
  TRANSFER_REJECTED
  TRANSFER_CANCELLED
  DISCREPANCY_ALERT
  LOW_STOCK
  ZERO_STOCK
}

enum AuditAction {
  USER_LOGIN
  USER_LOGOUT
  TRANSFER_CREATED
  TRANSFER_SENT
  ACCEPTANCE_SUBMITTED
  DISCREPANCY_DETECTED
  DISCREPANCY_RESOLVED
  TRANSFER_ACCEPTED
  TRANSFER_REJECTED
  TRANSFER_CANCELLED
  INVENTORY_ADJUSTED
  BALANCE_TOPUP
  BALANCE_EDITED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  EXPENSE_CREATED
  EXPENSE_DELETED
  COMPANY_LOSS_RECORDED
}

enum ResolutionType {
  ACCEPT_SENDER
  ACCEPT_RECEIVER
  ACCEPT_COMPROMISE
  ACCEPT_AS_IS
  CANCEL_TRANSFER
}

enum ShortageReason {
  SENDER_BLAMED      // Receiver was correct, sender loses
  RECEIVER_BLAMED    // Sender was correct, receiver loses
  SPLIT_LOSS         // Both share responsibility
}

// ──────────────────────────────────────────────
// AUTH & USERS
// ──────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String?  @unique
  username      String   @unique
  passwordHash  String   @map("password_hash")
  role          Role
  displayName   String   @map("display_name")
  isActive      Boolean  @default(true) @map("is_active")
  avatarUrl     String?  @map("avatar_url")

  // Scope — determines what this user manages
  officeId      String?  @map("office_id")
  countryId     String?  @map("country_id")
  cityId        String?  @map("city_id")

  office        Office?  @relation(fields: [officeId], references: [id])
  country       Country? @relation(fields: [countryId], references: [id])
  city          City?    @relation(fields: [cityId], references: [id])

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  refreshTokens    RefreshToken[]
  notifications    Notification[]
  auditLogs        AuditLog[]          @relation("AuditActor")
  acceptanceRecords AcceptanceRecord[]
  chatMessagesSent     ChatMessage[] @relation("ChatSender")
  chatMessagesReceived ChatMessage[] @relation("ChatReceiver")
  companyLossesResolved CompanyLoss[]

  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid())
  token       String   @unique
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  revokedAt   DateTime? @map("revoked_at")

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ──────────────────────────────────────────────
// OFFICES
// ──────────────────────────────────────────────

model Office {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique // e.g. "office-1", "office-2"
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  users     User[]
  countries Country[]
  inventory Inventory[]
  transfersSent     Transfer[] @relation("SenderOffice")
  transfersReceived Transfer[] @relation("ReceiverOffice")
  warehouseCreations WarehouseCreation[]
  shortages Shortage[]

  @@map("offices")
}

// ──────────────────────────────────────────────
// GEOGRAPHY
// ──────────────────────────────────────────────

model Country {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique // ISO-like: de, pl, nl, etc.
  latitude  Float    @default(0)
  longitude Float    @default(0)
  officeId  String?  @map("office_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  office    Office?  @relation(fields: [officeId], references: [id])
  cities    City[]
  users     User[]
  inventory Inventory[]
  transfersSent     Transfer[] @relation("SenderCountry")
  transfersReceived Transfer[] @relation("ReceiverCountry")
  shortages Shortage[]

  @@map("countries")
}

model City {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique // berlin, warsaw, etc.
  status    CityStatus @default(ACTIVE)
  latitude  Float      @default(0)
  longitude Float      @default(0)
  countryId String     @map("country_id")
  country   Country    @relation(fields: [countryId], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")

  // Relations
  users     User[]
  inventory Inventory[]
  expenses  Expense[]
  transfersSent     Transfer[] @relation("SenderCity")
  transfersReceived Transfer[] @relation("ReceiverCity")
  shortages Shortage[]

  @@unique([countryId, slug])
  @@map("cities")
}

// ──────────────────────────────────────────────
// INVENTORY
// ──────────────────────────────────────────────

model Inventory {
  id         String     @id @default(uuid())
  entityType EntityType @map("entity_type")
  officeId   String?    @map("office_id")
  countryId  String?    @map("country_id")
  cityId     String?    @map("city_id")
  itemType   ItemType   @map("item_type")
  quantity   Int        @default(0)
  updatedAt  DateTime   @updatedAt @map("updated_at")

  office     Office?    @relation(fields: [officeId], references: [id])
  country    Country?   @relation(fields: [countryId], references: [id])
  city       City?      @relation(fields: [cityId], references: [id])

  // Unique per entity+item combination
  @@unique([entityType, officeId, countryId, cityId, itemType], name: "unique_inventory_entry")
  @@index([itemType])
  @@index([entityType, officeId])
  @@index([entityType, countryId])
  @@index([entityType, cityId])
  @@map("inventory")
}

// ──────────────────────────────────────────────
// TRANSFERS
// ──────────────────────────────────────────────

model Transfer {
  id              String         @id @default(uuid())

  // Sender
  senderType      EntityType     @map("sender_type")
  senderOfficeId  String?        @map("sender_office_id")
  senderCountryId String?        @map("sender_country_id")
  senderCityId    String?        @map("sender_city_id")

  // Receiver
  receiverType    EntityType     @map("receiver_type")
  receiverOfficeId String?       @map("receiver_office_id")
  receiverCountryId String?      @map("receiver_country_id")
  receiverCityId  String?        @map("receiver_city_id")

  status          TransferStatus @default(SENT)
  version         Int            @default(0) // Optimistic locking
  notes           String?

  createdBy       String         @map("created_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  sentAt          DateTime?      @map("sent_at")
  acceptedAt      DateTime?      @map("accepted_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  // Relations
  senderOffice    Office?        @relation("SenderOffice", fields: [senderOfficeId], references: [id])
  senderCountry   Country?       @relation("SenderCountry", fields: [senderCountryId], references: [id])
  senderCity      City?          @relation("SenderCity", fields: [senderCityId], references: [id])
  receiverOffice  Office?        @relation("ReceiverOffice", fields: [receiverOfficeId], references: [id])
  receiverCountry Country?       @relation("ReceiverCountry", fields: [receiverCountryId], references: [id])
  receiverCity    City?          @relation("ReceiverCity", fields: [receiverCityId], references: [id])
  items           TransferItem[]
  rejection       TransferRejection?
  acceptanceRecords AcceptanceRecord[]
  companyLosses   CompanyLoss[]
  shortages       Shortage[]

  @@index([status])
  @@index([senderType, senderOfficeId])
  @@index([senderType, senderCountryId])
  @@index([senderType, senderCityId])
  @@index([receiverType, receiverOfficeId])
  @@index([receiverType, receiverCountryId])
  @@index([receiverType, receiverCityId])
  @@index([createdBy])
  @@map("transfers")
}

model TransferItem {
  id         String   @id @default(uuid())
  transferId String   @map("transfer_id")
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  itemType   ItemType @map("item_type")
  quantity   Int

  @@map("transfer_items")
}

model TransferRejection {
  id         String   @id @default(uuid())
  transferId String   @unique @map("transfer_id")
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  reason     String
  rejectedBy String   @map("rejected_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("transfer_rejections")
}

// ──────────────────────────────────────────────
// ACCEPTANCE (Blind acceptance records)
// ──────────────────────────────────────────────

model AcceptanceRecord {
  id               String   @id @default(uuid())
  transferId       String   @map("transfer_id")
  transfer         Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  itemType         ItemType @map("item_type")
  sentQuantity     Int      @map("sent_quantity")     // What was actually sent (hidden from receiver until accepted)
  receivedQuantity Int      @map("received_quantity") // What receiver counted
  discrepancy      Int      @default(0)               // sent - received (positive = shortage, negative = surplus)
  acceptedById     String   @map("accepted_by_id")
  acceptedBy       User     @relation(fields: [acceptedById], references: [id])
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([transferId, itemType], name: "unique_acceptance_per_item")
  @@index([transferId])
  @@map("acceptance_records")
}

// ──────────────────────────────────────────────
// ADJUSTMENTS (Admin manual changes)
// ──────────────────────────────────────────────

model Adjustment {
  id         String     @id @default(uuid())
  entityType EntityType @map("entity_type")
  officeId   String?    @map("office_id")
  countryId  String?    @map("country_id")
  cityId     String?    @map("city_id")
  itemType   ItemType   @map("item_type")
  delta      Int        // positive = add, negative = deduct
  reason     String
  createdBy  String     @map("created_by")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([entityType, officeId])
  @@index([entityType, countryId])
  @@index([entityType, cityId])
  @@map("adjustments")
}

// ──────────────────────────────────────────────
// EXPENSES (Events / Мероприятия)
// ──────────────────────────────────────────────

model Expense {
  id          String   @id @default(uuid())
  cityId      String   @map("city_id")
  city        City     @relation(fields: [cityId], references: [id])
  eventName   String   @map("event_name")
  eventDate   DateTime? @map("event_date")
  location    String?
  black       Int      @default(0)
  white       Int      @default(0)
  red         Int      @default(0)
  blue        Int      @default(0)
  notes       String?
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([cityId])
  @@index([eventDate])
  @@index([createdBy])
  @@map("expenses")
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ──────────────────────────────────────────────
// AUDIT LOG (IMMUTABLE)
// ──────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(uuid())
  actorId     String      @map("actor_id")
  actor       User        @relation("AuditActor", fields: [actorId], references: [id])
  action      AuditAction
  entityType  String      @map("entity_type")
  entityId    String      @map("entity_id")
  metadata    Json?       // before/after snapshots
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ──────────────────────────────────────────────
// EVENT STORE (CQRS / Event Sourcing)
// ──────────────────────────────────────────────

model DomainEvent {
  id            String   @id @default(uuid())
  aggregateType String   @map("aggregate_type")
  aggregateId   String   @map("aggregate_id")
  eventType     String   @map("event_type")
  version       Int
  payload       Json
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([aggregateId, version])
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([createdAt])
  @@map("domain_events")
}

// ──────────────────────────────────────────────
// CHAT MESSAGES
// ──────────────────────────────────────────────

model ChatMessage {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  sender     User     @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String   @map("receiver_id")
  receiver   User     @relation("ChatReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  text       String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([senderId, receiverId])
  @@index([receiverId, read])
  @@index([createdAt])
  @@map("chat_messages")
}

// ──────────────────────────────────────────────
// COMPANY LOSSES (Discrepancy resolution losses)
// ──────────────────────────────────────────────

model CompanyLoss {
  id              String         @id @default(uuid())
  transferId      String         @map("transfer_id")
  transfer        Transfer       @relation(fields: [transferId], references: [id])
  
  // Lost quantities by color
  black           Int            @default(0)
  white           Int            @default(0)
  red             Int            @default(0)
  blue            Int            @default(0)
  totalAmount     Int            @map("total_amount")
  
  // Resolution details
  resolutionType  ResolutionType @map("resolution_type")
  resolvedBy      String         @map("resolved_by")
  resolver        User           @relation(fields: [resolvedBy], references: [id])
  resolvedAt      DateTime       @default(now()) @map("resolved_at")
  
  // Transfer context (denormalized for quick display)
  senderName      String         @map("sender_name")
  senderCity      String?        @map("sender_city")
  receiverName    String         @map("receiver_name")
  receiverCity    String?        @map("receiver_city")
  originalSent    Int            @map("original_sent")
  originalReceived Int           @map("original_received")
  notes           String?

  @@index([transferId])
  @@index([resolvedBy])
  @@index([resolvedAt])
  @@map("company_losses")
}

// ──────────────────────────────────────────────
// SHORTAGES (Entity-specific shortage tracking from discrepancy resolution)
// ──────────────────────────────────────────────

model Shortage {
  id              String         @id @default(uuid())
  
  // Which entity has this shortage assigned
  entityType      EntityType     @map("entity_type")
  officeId        String?        @map("office_id")
  countryId       String?        @map("country_id")
  cityId          String?        @map("city_id")
  
  // Link to transfer
  transferId      String         @map("transfer_id")
  transfer        Transfer       @relation(fields: [transferId], references: [id])
  
  // Shortage amounts by color
  black           Int            @default(0)
  white           Int            @default(0)
  red             Int            @default(0)
  blue            Int            @default(0)
  totalAmount     Int            @map("total_amount")
  
  // Resolution details
  reason          ShortageReason
  resolutionType  ResolutionType @map("resolution_type")
  resolvedBy      String         @map("resolved_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  notes           String?
  
  // Relations for filtering
  office          Office?        @relation(fields: [officeId], references: [id])
  country         Country?       @relation(fields: [countryId], references: [id])
  city            City?          @relation(fields: [cityId], references: [id])

  @@index([entityType, officeId])
  @@index([entityType, countryId])
  @@index([entityType, cityId])
  @@index([transferId])
  @@index([resolvedBy])
  @@index([createdAt])
  @@map("shortages")
}

// ──────────────────────────────────────────────
// WAREHOUSE CREATION LOG (ADMIN/OFFICE bracelet creation)
// ──────────────────────────────────────────────

model WarehouseCreation {
  id          String     @id @default(uuid())
  entityType  EntityType @map("entity_type")  // ADMIN or OFFICE
  officeId    String?    @map("office_id")
  office      Office?    @relation(fields: [officeId], references: [id])
  
  // Created quantities by color
  black       Int        @default(0)
  white       Int        @default(0)
  red         Int        @default(0)
  blue        Int        @default(0)
  totalAmount Int        @map("total_amount")
  
  // Audit
  createdBy   String     @map("created_by")
  createdAt   DateTime   @default(now()) @map("created_at")
  notes       String?

  @@index([entityType, officeId])
  @@index([createdBy])
  @@index([createdAt])
  @@map("warehouse_creations")
}
